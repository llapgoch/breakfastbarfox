{
  "manifest_version": 2,
  "name": "Breakfast Bar Fox",
  "version": "1.0.0",
  "description": "Magento 2 developer toolbar in Firefox DevTools",
  "devtools_page": "devtools/devtools.html",
  "background": {
    "scripts": ["background/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "css": ["content/content-styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    "page/page-scanner.js"
  ],
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "permissions": [
    "activeTab",
    "tabs"
  ]
}
