{
  "name": "breakfastbarfox",
  "version": "1.0.0",
  "description": "Magento 2 developer toolbar in Firefox DevTools",
  "private": true,
  "scripts": {
    "lint": "web-ext lint",
    "start": "web-ext run",
    "build": "web-ext build --overwrite-dest",
    "sign": "set -a && . ./.env && set +a && web-ext sign --channel=unlisted"
  },
  "devDependencies": {
    "web-ext": "^10.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
